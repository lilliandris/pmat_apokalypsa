# Skopíruj tento súbor ako .env a uprav hodnoty. .env sa do gitu necommitne.

# Tajný kľúč na podpisovanie session cookies. V produkcii ho vždy zmeň na náhodný reťazec.
SESSION_SECRET=zmen-ma-na-nahodny-tajny-retazec

# Prihlasovacie údaje predvoleného admin účtu, ktorý sa vytvorí pri prvom spustení
# (len keď je databáza používateľov prázdna). Po prvom prihlásení si v admin paneli
# môžeš vytvoriť ďalšie účty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=zmen-ma

# Port, na ktorom server beží.
PORT=3000
